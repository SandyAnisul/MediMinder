# Copy this file to .env.local and fill in real values there.
# .env.local is git-ignored — never commit real secrets.

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# BotFather → /newbot
TELEGRAM_BOT_TOKEN=
# The bot's @username without the @ (e.g. mediminder_care_bot) — used to build invite links
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Make up long random strings for these two (e.g. from a password generator)
CRON_SECRET=
TELEGRAM_WEBHOOK_SECRET=

ADMIN_EMAIL=kaulsandeep@gmail.com

# Filled in after first Vercel deploy, e.g. https://mediminder.vercel.app
APP_URL=
